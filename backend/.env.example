# backend/.env.example
# Copiar este archivo a .env y configurar según necesidades

# Configuración de Flask
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# Configuración de CORS (permitir solicitudes desde frontend)
CORS_ORIGINS=http://localhost:3000

# Configuración del modelo
MODEL_PATH=modelo_chatbot.pkl
CONFIDENCE_THRESHOLD=0.3

# Configuración de logging
LOG_LEVEL=INFO
